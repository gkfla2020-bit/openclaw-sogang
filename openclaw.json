{
  "agents": {
    "defaults": {
      "model": {
        "primary": "sogang-gpt/gpt-5.1-chat-latest",
        "fallbacks": [
          "sogang-claude/claude-sonnet-4-5-20250929",
          "sogang-gpt/grok-4"
        ]
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "open",
      "botToken": "YOUR_TELEGRAM_BOT_TOKEN",
      "allowFrom": ["*"],
      "groupPolicy": "allowlist",
      "streaming": "partial"
    }
  },
  "gateway": {
    "mode": "local"
  },
  "models": {
    "mode": "merge",
    "providers": {
      "sogang-gpt": {
        "baseUrl": "https://factchat-cloud.mindlogic.ai/v1/api/openai",
        "apiKey": "YOUR_SOGANG_API_KEY",
        "api": "openai-completions",
        "models": [
          {
            "id": "gpt-5.1-chat-latest",
            "name": "GPT-5.1 (Sogang)",
            "reasoning": false,
            "input": ["text", "image"],
            "contextWindow": 128000,
            "maxTokens": 16384
          },
          {
            "id": "gpt-5-mini",
            "name": "GPT-5 Mini (Sogang)",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 128000,
            "maxTokens": 16384
          },
          {
            "id": "grok-4",
            "name": "Grok 4 (Sogang)",
            "reasoning": true,
            "input": ["text"],
            "contextWindow": 131072,
            "maxTokens": 8192
          }
        ]
      },
      "sogang-claude": {
        "baseUrl": "https://factchat-cloud.mindlogic.ai/v1/api/anthropic",
        "apiKey": "YOUR_SOGANG_API_KEY",
        "api": "anthropic-messages",
        "models": [
          {
            "id": "claude-sonnet-4-5-20250929",
            "name": "Claude Sonnet 4.5 (Sogang)",
            "reasoning": false,
            "input": ["text", "image"],
            "contextWindow": 200000,
            "maxTokens": 8192
          },
          {
            "id": "claude-opus-4-5-20251101",
            "name": "Claude Opus 4.5 (Sogang)",
            "reasoning": true,
            "input": ["text", "image"],
            "contextWindow": 200000,
            "maxTokens": 8192
          }
        ]
      }
    }
  }
}
